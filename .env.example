# Supabase Auth + Database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Gemini / image generation
GEMINI_API_KEY=your_gemini_api_key
GEMINI_BASE_URL=https://ai.t8star.cn/v1

# XAI / design suggestion
XAI_API_KEY=your_xai_api_key
XAI_BASE_URL=https://ai.t8star.cn/v1
XAI_MODEL=gpt-4o

# Video generation
VIDEO_API_KEY=your_video_api_key
VIDEO_API_BASE_URL=https://www.clockapi.fun/v1

# Remove background
# Available providers: stub, runninghub
REMOVE_BG_PROVIDER=stub

# Upscale
# Available providers: stub, runninghub
UPSCALE_PROVIDER=stub

# RunningHub
RUNNINGHUB_API_HOST=https://www.runninghub.cn
RUNNINGHUB_API_KEY=your_runninghub_api_key
RUNNINGHUB_REMOVE_BG_WEBAPP_ID=2039643601201799170
RUNNINGHUB_REMOVE_BG_INPUT_NODE_ID=141
RUNNINGHUB_REMOVE_BG_INPUT_FIELD_NAME=image
RUNNINGHUB_REMOVE_BG_INSTANCE_TYPE=default
RUNNINGHUB_UPSCALE_WEBAPP_ID=1925889402541658114
RUNNINGHUB_UPSCALE_INPUT_NODE_ID=2
RUNNINGHUB_UPSCALE_INPUT_FIELD_NAME=image
RUNNINGHUB_UPSCALE_SCALE_NODE_ID=217
RUNNINGHUB_UPSCALE_SCALE_FIELD_NAME=value
