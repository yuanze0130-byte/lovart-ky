# Supabase Auth + Database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
ADMIN_EMAILS=admin@example.com
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com

# Gemini / image generation
# proxy | official | auto
GEMINI_PROVIDER=proxy
GEMINI_API_KEY=your_gemini_api_key
GEMINI_BASE_URL=https://ai.t8star.cn/v1
GEMINI_PROXY_MODEL=gemini-3.1-flash-image-preview
GEMINI_PROXY_STANDARD_MODEL=nano-banana
GEMINI_PROXY_TEXT_MODEL=gpt-4o

# Object annotation / click-to-select detection
# Available providers: vision, stub, sam
OBJECT_DETECTION_PROVIDER=vision
# Optional. Defaults to GEMINI_* settings when omitted.
OBJECT_DETECTION_API_KEY=your_object_detection_api_key
OBJECT_DETECTION_BASE_URL=https://ai.t8star.cn/v1
OBJECT_DETECTION_MODEL=gpt-4o

# Segmentation provider (used when OBJECT_DETECTION_PROVIDER=sam)
OBJECT_SEGMENTATION_ENDPOINT=https://your-segmentation-service.example.com/detect
OBJECT_SEGMENTATION_API_KEY=your_segmentation_api_key
OBJECT_SEGMENTATION_TIMEOUT_MS=20000

# Gemini-compatible (official/native-style) endpoint, e.g. https://tapi.nyc.mn
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key
GOOGLE_GEMINI_BASE_URL=
GOOGLE_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview

# XAI / design suggestion
XAI_API_KEY=your_xai_api_key
XAI_BASE_URL=https://ai.t8star.cn/v1
XAI_MODEL=gpt-4o

# Video generation
VIDEO_API_KEY=your_video_api_key
VIDEO_API_BASE_URL=https://ai.t8star.cn
VIDEO_MODEL=doubao-seedance-2-0-260128
VIDEO_MODEL_STANDARD=doubao-seedance-2-0-260128
VIDEO_MODEL_FAST=doubao-seedance-2-0-fast-260128
VIDEO_REFERENCE_BUCKET=video-references

# Remove background
# Available providers: stub, runninghub
REMOVE_BG_PROVIDER=stub

# Upscale
# Available providers: stub, runninghub
UPSCALE_PROVIDER=stub

# RunningHub
RUNNINGHUB_API_HOST=https://www.runninghub.cn
RUNNINGHUB_API_KEY=your_runninghub_api_key
RUNNINGHUB_REMOVE_BG_WEBAPP_ID=2039643601201799170
RUNNINGHUB_REMOVE_BG_INPUT_NODE_ID=141
RUNNINGHUB_REMOVE_BG_INPUT_FIELD_NAME=image
RUNNINGHUB_REMOVE_BG_INSTANCE_TYPE=default
RUNNINGHUB_UPSCALE_WEBAPP_ID=1925889402541658114
RUNNINGHUB_UPSCALE_INPUT_NODE_ID=2
RUNNINGHUB_UPSCALE_INPUT_FIELD_NAME=image
RUNNINGHUB_UPSCALE_SCALE_NODE_ID=217
RUNNINGHUB_UPSCALE_SCALE_FIELD_NAME=value
RUNNINGHUB_UPSCALE_INSTANCE_TYPE=default
